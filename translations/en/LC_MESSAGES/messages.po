#: models/age_mode.py:23
msgid "Quel âge a la personne ? Devinez l'âge de la personne affichée"
msgstr "How old is this person? Guess the age of the displayed person"

#: models/arr_mode.py:21
msgid ""
"Mode ARR : Arcade Retro Racing - Évitez les obstacles et atteignez la "
"ligne d'arrivée !"
msgstr ""
"ARR Mode: Arcade Retro Racing - Dodge the obstacles and reach the finish "
"line!"

#: models/card_game_mode.py:23
msgid "Mode Jeu de Cartes : Affrontez l'IA dans un duel de cartes stratégique"
msgstr "Card Game Mode: Challenge the AI in a strategic card duel"

#: models/clue_mode.py:20
msgid "Mode indices : devinez qui est la personne avec le minimum d'indices"
msgstr "Clue Mode: guess who the person is with the fewest clues"

#: models/emoji_challenge_mode.py:21
msgid "Mode Défi Emoji : devinez qui est la personne représentée par ces emojis"
msgstr "Emoji Challenge Mode: guess who is represented by these emojis"

#: models/example_mode.py:20
msgid "Mode exemple : identifiez uniquement le nom de la personne sur l'image"
msgstr "Example Mode: identify only the name of the person in the image"

#: models/game_mode.py:138
msgid ""
"Identifiez l'entreprise, l'équipe, le nom et le poste de la personne sur "
"l'image"
msgstr "Identify the company, team, name and position of the person in the photo"

#: models/game_mode.py:219
msgid "Identifiez la personne correspondant au nom affiché"
msgstr "Identify the person matching the displayed name"

#: models/manager_mode.py:21
msgid "Qui est le manager de qui ? Identifiez le manager de la personne affichée"
msgstr "Who manages whom? Identify the manager of the displayed person"

#: models/memory_mode.py:20
msgid "Mode mémoire : associez les photos avec les noms en retournant des cartes"
msgstr "Memory Mode: match photos with names by flipping cards"

#: models/mirror_mode.py:29
msgid ""
"Mode Miroir : identifiez la personne dont l'image est inversée "
"horizontalement"
msgstr "Mirror Mode: identify the person whose image is flipped horizontally"

#: models/missing_person_mode.py:21
msgid "Mode personne manquante : identifiez qui manque dans l'équipe affichée"
msgstr "Missing Person Mode: identify who is missing from the displayed team"

#: models/pixelation_mode.py:20
msgid ""
"Mode pixelisation : identifiez la personne sur l'image qui devient "
"progressivement plus nette"
msgstr ""
"Pixelation Mode: identify the person in the image that progressively "
"becomes clearer"

#: models/position_match_mode.py:20
msgid "Mode poste : associez chaque employé avec son poste correct"
msgstr "Position Match Mode: match each employee with their correct position"

#: models/progressive_hint_mode.py:21
msgid ""
"Mode indices progressifs : identifiez l'employé avec le moins d'indices "
"possible pour gagner plus de points"
msgstr ""
"Progressive Hint Mode: identify the employee with as few hints as "
"possible to earn more points"

#: models/quiz_mode.py:21
msgid "Mode quiz : répondez à des questions variées sur vos collègues"
msgstr "Quiz Mode: answer various questions about your colleagues"

#: models/scrambled_face_mode.py:21
msgid ""
"Mode Visage Mélangé : identifiez la personne dont le visage a été mélangé"
" avec d'autres"
msgstr ""
"Scrambled Face Mode: identify the person whose face has been mixed with "
"others"

#: models/seniority_mode.py:22
msgid ""
"Combien d'années d'ancienneté ? Devinez depuis combien d'années la "
"personne travaille dans l'entreprise"
msgstr ""
"How many years of seniority? Guess how many years the person has been "
"working at the company"

#: models/silhouette_mode.py:20
msgid "Mode Silhouette : identifiez la personne à partir de sa silhouette"
msgstr "Silhouette Mode: identify the person from their silhouette"

#: models/speed_mode.py:20
msgid ""
"Mode vitesse : identifiez un maximum d'employés en un temps limité, plus "
"vous êtes rapide, plus vous gagnez de points"
msgstr ""
"Speed Mode: identify as many employees as possible in limited time, the "
"faster you are, the more points you earn"

#: models/team_guess_mode.py:20
msgid "Mode équipe : devinez à quelle équipe appartient chaque employé"
msgstr "Team Guess Mode: guess which team each employee belongs to"

#: models/team_mode.py:21
msgid "Mode équipe : identifiez tous les membres d'une équipe spécifique"
msgstr "Team Mode: identify all members of a specific team"

#: models/timed_mode.py:20
msgid "Mode chronométré : identifiez le maximum de personnes en 2 minutes"
msgstr "Timed Mode: identify as many people as possible in 2 minutes"

