#: templates/employee_edit.html:176 templates/setup_wizard.html:400
msgid "Manager"
msgstr "Manager"

#: models/manager_mode.py:30
msgid "Qui est le manager de qui ? Identifiez le manager de la personne affichée"
msgstr "Who manages whom? Identify the manager of the displayed person"

#: models/memory_mode.py:31 routes/game_routes.py:26
msgid "Mémoire"
msgstr "Memory"

#: models/memory_mode.py:35
msgid "Mode mémoire : associez les photos avec les noms en retournant des cartes"
msgstr "Memory Mode: match photos with names by flipping cards"

#: models/mirror_mode.py:38
msgid "Miroir"
msgstr "Mirror"

#: models/mirror_mode.py:42
msgid "Mode Miroir : identifiez la personne dont l'image est inversée horizontalement"
msgstr "Mirror Mode: identify the person whose image is flipped horizontally"

#: models/missing_person_mode.py:30
msgid "Personne manquante"
msgstr "Missing Person"

#: models/missing_person_mode.py:34
msgid "Mode personne manquante : identifiez qui manque dans l'équipe affichée"
msgstr "Missing Person Mode: identify who is missing from the displayed team"

#: models/pixelation_mode.py:28
msgid "Pixélisation"
msgstr "Pixelation"

#: models/pixelation_mode.py:32
msgid ""
"Mode pixelisation : identifiez la personne sur l'image qui devient "
"progressivement plus nette"
msgstr ""
"Pixelation Mode: identify the person in the image that progressively becomes "
"clearer"

#: models/position_match_mode.py:41
msgid "Association de postes"
msgstr "Position Match"

#: models/position_match_mode.py:45
msgid "Mode poste : associez chaque employé avec son poste correct"
msgstr "Position Match Mode: match each employee with their correct position"

#: models/progressive_hint_mode.py:33
msgid "Indices progressifs"
msgstr "Progressive Hints"

#: models/progressive_hint_mode.py:37
msgid ""
"Mode indices progressifs : identifiez l'employé avec le moins d'indices "
"possible pour gagner plus de points"
msgstr ""
"Progressive Hint Mode: identify the employee with as few hints as possible to"
" earn more points"

#: models/quiz_mode.py:29
msgid "Quiz"
msgstr "Quiz"

#: models/quiz_mode.py:33
msgid "Mode quiz : répondez à des questions variées sur vos collègues"
msgstr "Quiz Mode: answer various questions about your colleagues"

#: models/scrambled_face_mode.py:30
msgid "Visage mélangé"
msgstr "Scrambled Face"

#: models/scrambled_face_mode.py:34
msgid ""
"Mode Visage Mélangé : identifiez la personne dont le visage a été mélangé "
"avec d'autres"
msgstr "Scrambled Face Mode: identify the person whose face has been mixed with others"

#: models/seniority_mode.py:27
msgid "Ancienneté"
msgstr "Seniority"

#: models/seniority_mode.py:31
msgid ""
"Combien d'années d'ancienneté ? Devinez depuis combien d'années la personne "
"travaille dans l'entreprise"
msgstr ""
"How many years of seniority? Guess how many years the person has been working"
" at the company"

#: models/silhouette_mode.py:29
msgid "Silhouette"
msgstr "Silhouette"

#: models/silhouette_mode.py:33
msgid "Mode Silhouette : identifiez la personne à partir de sa silhouette"
msgstr "Silhouette Mode: identify the person from their silhouette"

#: models/speed_mode.py:30
msgid "Vitesse"
msgstr "Speed"

#: models/speed_mode.py:34
msgid ""
"Mode vitesse : identifiez un maximum d'employés en un temps limité, plus vous"
" êtes rapide, plus vous gagnez de points"
msgstr ""
"Speed Mode: identify as many employees as possible in limited time, the "
"faster you are, the more points you earn"

#: models/team_guess_mode.py:27
msgid "Devine l'équipe"
msgstr "Guess the Team"

#: models/team_guess_mode.py:31
msgid "Mode équipe : devinez à quelle équipe appartient chaque employé"
msgstr "Team Guess Mode: guess which team each employee belongs to"

#: models/team_mode.py:29 templates/_mode_preview.html:45
